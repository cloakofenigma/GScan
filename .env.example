# G-Hunter Configuration File
# Copy this file to .env and fill in your actual values

# GitHub Personal Access Token (Required)
# Get yours at: https://github.com/settings/tokens
# Required scopes: public_repo
GITHUB_TOKEN=ghp_your_github_token_here

# Google Gemini API Key (Optional - for AI analysis)
# Get yours at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (Optional - defaults to gemini-2.5-flash, which has a free tier).
# Override only if you want a different model.
# GEMINI_MODEL=gemini-2.5-flash
